              ".read": "auth != null && auth.token.email_verified == true && (auth.token.email == 'shower.li@yutesign.com' || root.child('ops/companies').child($companyId).child('v1/users').child(auth.uid).child('role').val() == 'owner' || root.child('ops/companies').child($companyId).child('v1/users').child(auth.uid).child('role').val() == 'tenantAdmin' || root.child('ops/companies').child($companyId).child('v1/users').child(auth.uid).child('role').val() == 'finance')",
              "$logId": {
                ".write": "auth != null && auth.token.email_verified == true && (auth.token.email == 'shower.li@yutesign.com' || root.child('ops/companies').child($companyId).child('v1/users').child(auth.uid).child('active').val() == true) && !data.exists() && newData.child('actorUid').val() == auth.uid",
                ".validate": "newData.hasChildren(['companyId', 'actorUid', 'action', 'targetType', 'targetId', 'at']) && newData.child('companyId').val() == $companyId && newData.child('action').isString() && newData.child('targetType').isString() && newData.child('targetId').isString() && newData.child('at').isNumber()"
              }
            }
          }
        }
      }
    }
  }
}
